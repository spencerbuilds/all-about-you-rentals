# All About You Rentals — Environment Variables
# Copy this to .env.local for local dev, or add to Vercel Dashboard > Settings > Environment Variables

# ── Supabase (https://supabase.com — free tier) ───────────────
# 1. Create a new project at supabase.com
# 2. Go to Project Settings > API
# 3. Copy Project URL and service_role key (NOT anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin Authentication ──────────────────────────────────────
# Choose a strong password for the admin panel login
ADMIN_PASSWORD=choose-a-strong-password

# Choose a long random string as the API secret (like a JWT secret)
# Generate one at: https://generate-secret.vercel.app/32
ADMIN_SECRET=your-long-random-secret-here

# ── Email Notifications (https://resend.com — free: 3000/mo) ─
# 1. Create account at resend.com
# 2. Get your API key from the dashboard
RESEND_API_KEY=re_xxxxxxxxx

# Email address to receive booking notifications
ADMIN_EMAIL=your@email.com
